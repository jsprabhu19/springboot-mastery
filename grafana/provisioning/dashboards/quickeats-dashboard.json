          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_sum{uri=~\"/api/v1/orders.*\"}[5m])) / sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/orders.*\"}[5m]))",
          "legendFormat": "Average Latency",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Order Service Request Latency",
      "type": "timeseries"
